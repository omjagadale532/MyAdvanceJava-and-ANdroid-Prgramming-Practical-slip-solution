//MainActivity.java
package com.example.employeeapp;

import android.os.Bundle;
import android.view.View;
import android.widget.Button;
import android.widget.EditText;
import android.widget.TextView;
import androidx.appcompat.app.AppCompatActivity;

public class MainActivity extends AppCompatActivity {
 EditText ename, designation, salary;
 Button insertBtn, showBtn;
 TextView resultText;
 DBHelper dbHelper;

 @Override
 protected void onCreate(Bundle savedInstanceState) {
     super.onCreate(savedInstanceState);
     setContentView(R.layout.activity_main);

     ename = findViewById(R.id.ename);
     designation = findViewById(R.id.designation);
     salary = findViewById(R.id.salary);
     insertBtn = findViewById(R.id.insertBtn);
     showBtn = findViewById(R.id.showBtn);
     resultText = findViewById(R.id.resultText);
     dbHelper = new DBHelper(this);

     insertBtn.setOnClickListener(new View.OnClickListener() {
         @Override
         public void onClick(View v) {
             String name = ename.getText().toString();
             String desig = designation.getText().toString();
             double sal = Double.parseDouble(salary.getText().toString());
             dbHelper.insertEmployee(name, desig, sal);
             resultText.setText("Employee Inserted");
         }
     });

     showBtn.setOnClickListener(new View.OnClickListener() {
         @Override
         public void onClick(View v) {
             resultText.setText(dbHelper.getAllEmployees());
         }
     });
 }
}




