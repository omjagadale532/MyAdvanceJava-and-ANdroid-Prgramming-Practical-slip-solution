package com.example.gameapp;

import android.database.Cursor;
import android.os.Bundle;
import android.view.View;
import android.widget.*;

import androidx.appcompat.app.AppCompatActivity;

public class MainActivity extends AppCompatActivity {

    DBHelper dbHelper;
    Button btnUpdate, btnDisplay;
    TextView tvResult;

    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);
        setContentView(R.layout.activity_main);

        dbHelper = new DBHelper(this);
        btnUpdate = findViewById(R.id.btnUpdate);
        btnDisplay = findViewById(R.id.btnDisplay);
        tvResult = findViewById(R.id.tvResult);

        btnUpdate.setOnClickListener(new View.OnClickListener() {
            @Override
            public void onClick(View v) {

                dbHelper.updatePlayers();
                Toast.makeText(MainActivity.this, "Updated Successfully", Toast.LENGTH_SHORT).show();
            }
        });

        btnDisplay.setOnClickListener(new View.OnClickListener() {
            @Override
            public void onClick(View v) {

                Cursor cursor = dbHelper.getAllData();
                StringBuilder sb = new StringBuilder();

                while (cursor.moveToNext()) {
                    sb.append("GNo: ").append(cursor.getInt(0)).append("\n");
                    sb.append("Name: ").append(cursor.getString(1)).append("\n");
                    sb.append("Type: ").append(cursor.getString(2)).append("\n");
                    sb.append("Players: ").append(cursor.getInt(3)).append("\n\n");
                }

                tvResult.setText(sb.toString());
            }
        });
    }
