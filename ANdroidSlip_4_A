package com.example.studentapp;

import android.content.Intent;
import android.os.Bundle;
import android.view.View;
import android.widget.*;
import androidx.appcompat.app.AppCompatActivity;

public class MainActivity extends AppCompatActivity {

    EditText name, surname, cls, marks;
    RadioButton male, female;
    CheckBox cricket, reading, singing;
    Button submit;

    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);
        setContentView(R.layout.activity_main);

        name = findViewById(R.id.name);
        surname = findViewById(R.id.surname);
        cls = findViewById(R.id.cls);
        marks = findViewById(R.id.marks);
        male = findViewById(R.id.male);
        female = findViewById(R.id.female);
        cricket = findViewById(R.id.cricket);
        reading = findViewById(R.id.reading);
        singing = findViewById(R.id.singing);
        submit = findViewById(R.id.submit);

        submit.setOnClickListener(new View.OnClickListener() {
            public void onClick(View v) {
                String gender = male.isChecked() ? "Male" : "Female";

                String hobbies = "";
                if (cricket.isChecked()) hobbies += "Cricket ";
                if (reading.isChecked()) hobbies += "Reading ";
                if (singing.isChecked()) hobbies += "Singing ";

                Intent i = new Intent(MainActivity.this, SecondActivity.class);
                i.putExtra("name", name.getText().toString());
                i.putExtra("surname", surname.getText().toString());
                i.putExtra("class", cls.getText().toString());
                i.putExtra("gender", gender);
                i.putExtra("hobbies", hobbies);
                i.putExtra("marks", marks.getText().toString());
                startActivity(i);
            }
        });
    }
}


//2) SecondActivity.java
package com.example.studentapp;

import android.os.Bundle;
import android.widget.TextView;
import androidx.appcompat.app.AppCompatActivity;

public class SecondActivity extends AppCompatActivity {

    TextView tv;

    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);
        setContentView(R.layout.activity_second);

        tv = findViewById(R.id.tv);

        String data =
                "Name\t\t: " + getIntent().getStringExtra("name") + "\n" +
                "Surname\t: " + getIntent().getStringExtra("surname") + "\n" +
                "Class\t\t: " + getIntent().getStringExtra("class") + "\n" +
                "Gender\t: " + getIntent().getStringExtra("gender") + "\n" +
                "Hobbies\t: " + getIntent().getStringExtra("hobbies") + "\n" +
                "Marks\t\t: " + getIntent().getStringExtra("marks");

        tv.setText(data);
    }
}



